# Server Port
PORT=<YOUR_BACKEND_PORT_VALUE>

# Environment Mode (development | staging | production)
NODE_ENV=development

# PostgreSQL Connection String
# Format: postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE_NAME>?schema=<SCHEMA>
# Examples:
#     Local: postgresql://postgres:postgres@localhost:5432/lifetag_db?schema=public
#     Supabase: postgresql://postgres.xxxx:yourpassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#     Neon: postgresql://user:password@ep-cool-name.us-east-2.aws.neon.tech/lifetag?sslmode=require
DATABASE_URL="postgresql://<USERNAME>:<PASSWORD>@localhost:5432/<DATABASE_NAME>?schema=public"

# Authentication Secrets (No JWT expiration configured)
JWT_SECRET=<YOUR_JWT_SECRET_KEY>

# Frontend URL for CORS
# Examples:
# http://localhost:5173
# https://lifetag.example.com
CORS_ORIGIN=<YOUR_FRONTEND_URL>
